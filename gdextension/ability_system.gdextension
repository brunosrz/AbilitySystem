ios.debug.arm64 = "res://addons/ability_system/bin/libability_system.ios.editor.arm64.dylib"
ios.release.arm64 = "res://addons/ability_system/bin/libability_system.ios.template_release.arm64.dylib"

web.debug.wasm32 = "res://addons/ability_system/bin/libability_system.web.editor.wasm32.wasm"
web.release.wasm32 = "res://addons/ability_system/bin/libability_system.web.template_release.wasm32.wasm"

