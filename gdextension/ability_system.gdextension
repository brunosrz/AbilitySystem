android.release.arm32 = "res://addons/ability_system/bin/libability_system.android.template_release.arm32.so"
android.debug.x86_64 = "res://addons/ability_system/bin/libability_system.android.editor.x86_64.so"
android.release.x86_64 = "res://addons/ability_system/bin/libability_system.android.template_release.x86_64.so"
