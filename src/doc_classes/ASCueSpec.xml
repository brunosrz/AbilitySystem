<?xml version="1.0" encoding="UTF-8" ?>
<class name="ASCueSpec" inherits="RefCounted" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../doc/class.xsd">
	<brief_description>
		Runtime context for a cue execution.
	</brief_description>
	<description>
		[ASCueSpec] provides context for visual/audio effects, such as who triggered it and where it happened.
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="get_level" qualifiers="const">
			<return type="float" />
			<description>
				Returns the level of the cue spec.
			</description>
		</method>
		<method name="set_level">
			<return type="void" />
			<param index="0" name="level" type="float" />
			<description>
				Sets the level of the cue spec.
			</description>
		</method>
	</methods>
	<members>
		<member name="cue" type="ASCue" setter="set_cue" getter="get_cue">
			The definition resource.
		</member>
		<member name="effect_spec" type="ASEffectSpec" setter="set_effect_spec" getter="get_effect_spec">
			The associated effect specification that triggered this cue.
		</member>
		<member name="extra_data" type="Dictionary" setter="set_extra_data" getter="get_extra_data" default="{}">
			Any extra data passed to the cue.
		</member>
		<member name="hit_position" type="Variant" setter="set_hit_position" getter="get_hit_position" default="null">
			Position.
		</member>
		<member name="magnitude" type="float" setter="set_magnitude" getter="get_magnitude" default="0.0">
			Calculated magnitude.
		</member>
		<member name="source_asc" type="ASComponent" setter="set_source_asc" getter="get_source_asc">
			The component that originated the cue.
		</member>
		<member name="target_asc" type="ASComponent" setter="set_target_asc" getter="get_target_asc">
			The component the cue is applied to.
		</member>
		<member name="target_node" type="Object" setter="set_target_node" getter="get_target_node">
			The target Node the cue is playing on.
		</member>
	</members>
</class>
