# ==============================================================================
# PROJECT IDENTITY (The Plugin)
# ==============================================================================
PROJECT_ID=ability-system
PLUGIN_VER=0.1.0
MODULE_NAME=ability_system

# ==============================================================================
# GODOT ENGINE (Base for Export & CI)
# ==============================================================================
GODOT_VERSION=4.6.1
GODOT_STATUS=stable
GODOT_VERSION_FOR_EXPORT=4.6.1-stable
GODOT_RELEASES_URL=https://github.com/godotengine/godot/releases/download

# ==============================================================================
# GODOT-CPP (GDExtension SDK)
# ==============================================================================
GODOT_CPP_REPO=https://github.com/godotengine/godot-cpp.git
GODOT_CPP_API_VERSION=master

# ==============================================================================
# ZYRIS ENGINE (Base for Module Build)
# ==============================================================================
ZYRIS_REPO=Kaffyn/ZyrisEngine
ZYRIS_BRANCH=no-ability-system
ZYRIS_VER=0.3.0

# ==============================================================================
# INTEGRATION (LimboAI Demo & Tests)
# ==============================================================================
PROJECT_INTEGRATION_NAME=limboai
PROJECT_INTEGRATION_GITHUB=limbonaut/limboai
PROJECT_INTEGRATION_VERSION=1.7.0
PROJECT_INTEGRATION_PACKAGE_PLUGIN=limboai+v1.7.0.gdextension-4.6.zip

# ==============================================================================
# BUILD TOOLS & PLATFORMS
# ==============================================================================
# Common
SCONS_VERSION=4.10.1
PYTHON_VERSION=3.x
FLOAT_PRECISION=single

# Android
JAVA_VERSION=17
NDK_VERSION=r28b
NDK_FULL_VERSION=28.1.13356709

# Web
EM_VERSION=4.0.11
