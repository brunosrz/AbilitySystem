; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[ability_system]

common/name_tags=PackedStringArray("acceleration", "air_resistance", "coyote_time", "effect.damage", "effect.dash_cost", "friction", "gravity_scale", "health", "jump_buffer_time", "jump_force", "max_speed", "package.melee_hit", "stamina", "stamina_regen")
common/event_tags=PackedStringArray("Event.Attack.Hit", "event.attack.hit")
common/conditional_tags=PackedStringArray("armor.diamond", "armor.gold", "armor.iron", "armor.steel", "attack.charged", "attack.dash_attack", "attack.fast", "attack.normal", "attack.special", "effect.electric", "effect.fire", "effect.ice", "effect.poison", "env_type.ledge", "env_type.open", "env_type.tight_corridor", "env_type.water_surface", "game_state.cutscene", "game_state.menu", "game_state.paused", "game_state.playing", "input_source.ai", "input_source.cinematic", "input_source.force", "input_source.player", "jump.fall", "jump.high", "jump.low", "motion.dash", "motion.idle", "motion.run", "motion.walk", "physics.air", "physics.ground", "physics.water", "stance.block", "stance.climb", "stance.cover", "stance.crouch", "stance.stand", "state.dead", "state.hurt", "state.hyperdash", "status.dead", "status.hurt", "status.invulnerable", "status.normal", "status.stunned", "status.super_armor", "tier.base", "tier.corrupted", "tier.master", "tier.upgraded", "weapon.bow", "weapon.katana", "weapon.unarmed")

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Demo Ability System"
run/main_scene="res://ui/user_registration.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameData="*res://autoload/GameData.gd"
GameMachine="*res://autoload/GameMachine.gd"
MultiplayerGameManager="*res://autoload/MultiplayerGameManager.gd"
RBAC="*res://autoload/RBAC.gd"
AdminCommand="*res://autoload/AdminCommand.gd"
AdminTerminal="*res://autoload/AdminTerminal.gd"
ServerLogger="*res://autoload/ServerLogger.gd"
SystemVerification="*res://autoload/SystemVerification.gd"
AudioManager="*res://autoload/AudioManager.gd"

